# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 基础URL（生产环境使用）
#BASE_URL=https://app-test.b18a.io
BASE_URL=https://app.codatta.io

# 私钥（带0x前缀）
PRIVATE_KEY=0x40e68d7c277fbbd3399e7568011ec02cdb5f1009c1db15d883ef51bb41deb028

# 区块链配置
CHAIN_ID=56
CHAIN=56

# 钱包配置
WALLET_NAME=OKX Wallet
CONNECTOR=codatta_wallet

# 设备信息
DEVICE=WEB
CHANNEL=codatta-platform-website
APP=codatta-platform-website

# 测试环境
TEST_ENV=test
